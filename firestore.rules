rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 管理者権限の判定ロジック。
    // @hgu.jpドメインまたは特定の管理者メールアドレスを許可。
    function isAuthorizedEditor() {
      return request.auth != null && 
             request.auth.token.email != null && (
               request.auth.token.email.lower().endsWith('@hgu.jp') || 
               request.auth.token.email == "admin@example.com"
             );
    }

    // すべての管理対象ドキュメントに対して、認証済みエディターのフルアクセスを許可
    match /articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if isAuthorizedEditor();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAuthorizedEditor();
    }

    match /hero-images/{imageId} {
      allow read: if true;
      allow create, update, delete: if isAuthorizedEditor();
    }

    // デフォルトはすべて拒否
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
