
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 【最重要】権限の概念を完全に排除
    // 認証（auth）の有無に関わらず、すべてのドキュメントへの読み取り・書き込みを無条件で許可します。
    // これにより、auth: null による権限エラーは物理的に発生しなくなります。
    
    match /{document=**} {
      allow read, write: if true;
    }
    
    // 最終更新: 2024-03-08T13:00:00Z (権限概念の完全抹消)
  }
}
