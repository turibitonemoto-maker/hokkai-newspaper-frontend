
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 【重要】パブリックアクセスの完全許可
    // 認証状態（auth）を一切問わず、記事やカテゴリーの読み取りを許可します。
    // これにより auth: null による権限エラーを完全に防止します。
    
    match /articles/{articleId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /hero-images/{imageId} {
      allow read: if true;
      allow write: if false;
    }
    
    // 全体的なフォールバック
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // 最終更新: 2024-03-08T12:00:00Z (Announcementsタブ追加に伴うパブリック権限の再徹底)
  }
}
