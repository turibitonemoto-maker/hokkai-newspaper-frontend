
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 許可された特定のメールアドレスまたはドメインのチェック
    function isAuthorizedEditor() {
      return request.auth != null && (
        request.auth.token.email == "admin@example.com" || 
        request.auth.token.email.endsWith("@hgu.jp")
      );
    }

    // 記事のルール: 閲覧は全員に許可、書き込みは特定の認証済みユーザーのみ
    match /articles/{articleId} {
      allow read, list: if true;
      allow write: if isAuthorizedEditor();
    }

    // カテゴリー: 閲覧は全員、書き込みは特定の認証済みユーザーのみ
    match /categories/{categoryId} {
      allow read, list: if true;
      allow write: if isAuthorizedEditor();
    }

    // デフォルトで全てのアクセスを拒否
    match /{path=**} {
      allow read, write: if false;
    }
    
    // ルール更新強制コメント: 2024-05-24 11:30 - Google Auth Provider設定の確認と同期
  }
}
