rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 管理者権限の判定ロジック。
    // @hgu.jpドメインまたは特定の管理者メールアドレスを許可。
    function isAuthorizedEditor() {
      return request.auth != null && 
             request.auth.token.email != null && (
               request.auth.token.email.lower().endsWith('@hgu.jp') || 
               request.auth.token.email == "admin@example.com" ||
               request.auth.token.email == "4325132k@hgu.jp"
             );
    }

    // 記事（articles）のルール
    match /articles/{articleId} {
      allow read: if true;
      // create, update, delete を明示的に許可
      allow create, update, delete: if isAuthorizedEditor();
    }

    // カテゴリー（categories）のルール
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAuthorizedEditor();
    }

    // ヒーロー画像（hero-images）のルール
    match /hero-images/{imageId} {
      allow read: if true;
      allow create, update, delete: if isAuthorizedEditor();
    }

    // デフォルトはすべて拒否
    match /{path=**} {
      allow read, write: if false;
    }
  }
}