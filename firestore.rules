rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ニュースサイトとして、全ての閲覧用データを完全に公開
    // auth: null (未ログイン) の状態でも読み取り (list, get) を許可します
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // Deployment Token: 2024-03-08T08:15:00Z (Emergency Permissions Reset)
  }
}