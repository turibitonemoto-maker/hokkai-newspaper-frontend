rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ニュースサイトとして、全ての閲覧用データを完全に公開
    // auth: null (未ログイン) の状態でも読み取り (list, get) を無条件で許可します
    match /articles/{document=**} {
      allow read: if true;
    }
    match /categories/{document=**} {
      allow read: if true;
    }
    match /hero-images/{document=**} {
      allow read: if true;
    }
    
    // 全体的なフォールバック（読み取り許可、書き込み禁止）
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // Deployment Token: 2024-03-08T08:30:00Z (Rules Fully Opened for Public Browsing)
  }
}