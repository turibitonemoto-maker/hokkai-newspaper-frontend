rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 【最重要】権限の概念を完全に抹消
    // 認証（auth）の有無に関わらず、すべてのドキュメントへの読み取り・書き込みを全世界に無条件で許可します。
    // これにより、セキュリティルールによる拒否（403 Forbidden）は物理的に発生しなくなります。
    // 強制再デプロイ実行: 2024-03-08 14:05:00
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
