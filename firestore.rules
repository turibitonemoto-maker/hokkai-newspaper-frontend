rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 全てのドキュメントに対して、認証の有無（auth == null等）に関わらず
    // 読み取り（get, list）および書き込み（create, update, delete）を完全に許可します。
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Deployment trigger: 2024-05-25T18:00:00Z (Emergency Overhaul: Fully Open & Public)
  }
}