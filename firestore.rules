rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 【表示用アプリの権限確立】
    // 1. 閲覧（read）は全世界に公開
    // 2. 書き込み（write）は、認証された特定の管理者のみに制限
    
    match /{document=**} {
      // 誰でも閲覧可能
      allow read: if true;
      
      // 書き込みは「ログインしていること」かつ「特定のメールアドレスであること」を条件にする
      // ※ 下記の "your-admin-email@example.com" をあなたのGmailアドレスなどに書き換えてください
      allow write: if request.auth != null && 
                     (request.auth.token.email == "your-admin-email@example.com" || 
                      request.auth.token.email_verified == true);
    }
  }
}
