
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 管理者権限の判定ロジック
    function isAuthorizedEditor() {
      return request.auth != null && 
             request.auth.token.email != null && (
               request.auth.token.email.lower().endsWith('@hgu.jp') || 
               request.auth.token.email.lower() == "turibitonemoto@gmail.com" ||
               request.auth.token.email.lower() == "admin@example.com"
             );
    }

    // 記事：読み取りは全員（get, list 共に許可）、書き込みは許可されたメンバーのみ
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAuthorizedEditor();
    }

    // カテゴリー：読み取りは全員、書き込みは許可されたメンバーのみ
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAuthorizedEditor();
    }

    // ヒーロー画像：読み取りは全員、書き込みは許可されたメンバーのみ
    match /hero-images/{imageId} {
      allow read: if true;
      allow write: if isAuthorizedEditor();
    }

    // デフォルトはすべて拒否
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
