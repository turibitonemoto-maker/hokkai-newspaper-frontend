rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 編集者権限の判定関数
    function isEditor() {
      return request.auth != null && 
             request.auth.token.email != null && (
               request.auth.token.email.lower().endsWith('@hgu.jp') || 
               request.auth.token.email.lower() == "turibitonemoto@gmail.com" ||
               request.auth.token.email.lower() == "admin@example.com"
             );
    }

    // 記事（articles）
    match /articles/{articleId} {
      // 閲覧（get, list）は一般公開
      allow read: if true;
      // 書き込み（create, update, delete）は編集者のみ
      allow write: if isEditor();
    }

    // カテゴリー（categories）
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isEditor();
    }

    // ヒーロー画像（hero-images）
    match /hero-images/{imageId} {
      allow read: if true;
      allow write: if isEditor();
    }

    // デフォルトはすべて拒否
    match /{path=**} {
      allow read, write: if false;
    }
  }
}