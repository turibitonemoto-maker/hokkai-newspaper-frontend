rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 編集者権限の判定関数
    function isEditor() {
      return request.auth != null && 
             request.auth.token.email != null && (
               request.auth.token.email.lower().endsWith('@hgu.jp') || 
               request.auth.token.email.lower() == "turibitonemoto@gmail.com" ||
               request.auth.token.email.lower() == "admin@example.com" ||
               request.auth.token.email.lower() == "4325132k@hgu.jp"
             );
    }

    // 記事（articles）: 全員読み取り可能、編集者のみ書き込み可能
    match /articles/{articleId} {
      allow read, get, list: if true;
      allow create, update, delete: if isEditor();
    }

    // カテゴリー（categories）: 全員読み取り可能、編集者のみ書き込み可能
    match /categories/{categoryId} {
      allow read, get, list: if true;
      allow create, update, delete: if isEditor();
    }

    // ヒーロー画像（hero-images）: 全員読み取り可能、編集者のみ書き込み可能
    match /hero-images/{imageId} {
      allow read, get, list: if true;
      allow create, update, delete: if isEditor();
    }

    // デフォルトはすべて拒否
    match /{path=**} {
      allow read, write: if false;
    }
  }
}