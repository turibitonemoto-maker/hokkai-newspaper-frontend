rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 記事 (articles) & カテゴリー (categories): 
    // 表示側のエラーを確実に止めるため、読み取り権限を完全に開放
    match /articles/{articleId} {
      allow read: if true;
      allow write: if request.auth != null && 
                   (request.auth.token.email.lower().endsWith('@hgu.jp') || 
                    request.auth.token.email == 'admin@example.com');
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /hero-images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // デフォルト拒否
    match /{path=**} {
      allow read, write: if false;
    }
    
    // Security Rules deployment trigger: 2024-05-24T23:30:00Z (Emergency Fix: Enforce Public Read)
  }
}