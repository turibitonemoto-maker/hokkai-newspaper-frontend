rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 編集者権限の判定関数（大学ドメインおよび個別許可メール）
    function isEditor() {
      return request.auth != null && 
             request.auth.token.email != null && (
               request.auth.token.email.lower().endsWith('@hgu.jp') || 
               request.auth.token.email.lower() == "turibitonemoto@gmail.com" ||
               request.auth.token.email.lower() == "admin@example.com"
             );
    }

    // 記事（articles）
    // 閲覧（get, list）は一般公開。書き込み（create, update, delete）は編集者のみ。
    // list権限を明示的に許可し、大学アカウントでの一覧表示を確実にします。
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isEditor();
    }

    // カテゴリー（categories）
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isEditor();
    }

    // ヒーロー画像（hero-images）
    match /hero-images/{imageId} {
      allow read: if true;
      allow write: if isEditor();
    }

    // デフォルトはすべて拒否
    match /{path=**} {
      allow read, write: if false;
    }
  }
}