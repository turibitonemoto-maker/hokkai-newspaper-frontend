rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 大学メール（@hgu.jp）または指定の管理者の判定
    function isHguUser() {
      return request.auth != null && 
             request.auth.token.email != null && (
               request.auth.token.email.lower().endsWith('@hgu.jp') || 
               request.auth.token.email.lower() == "admin@example.com"
             );
    }

    // 記事（articles）
    match /articles/{articleId} {
      // 大学関係者のみ読み取り・書き込みを許可（list権限エラー対策）
      allow read, write: if isHguUser();
    }

    // カテゴリー（categories）
    match /categories/{categoryId} {
      allow read, write: if isHguUser();
    }

    // ヒーロー画像（hero-images）
    match /hero-images/{imageId} {
      allow read, write: if isHguUser();
    }

    // デフォルトはすべて拒否
    match /{path=**} {
      allow read, write: if false;
    }
    
    // Security Rules deployment trigger: 2024-05-20T16:00:00Z (Updated for explicit list permission and restricted access)
  }
}