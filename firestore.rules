rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 記事のルール: 閲覧は全員に許可（get/listの両方を明示的に許可）
    match /articles/{articleId} {
      allow read: if true;
      allow list: if true;
      allow write: if request.auth != null;
    }

    // カテゴリー: 閲覧は全員、書き込みは認証済みユーザーのみ
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ルール再適用のための強制コメント: 2024-05-23 セキュリティルールの最適化
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
