rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 権限チェック: 大学ドメイン（@hgu.jp）または指定の管理者
    function isAuthorizedUser() {
      return request.auth != null && 
             request.auth.token.email != null && 
             (request.auth.token.email.lower().endsWith('@hgu.jp') || request.auth.token.email == 'admin@example.com');
    }

    // 記事（articles）
    match /articles/{articleId} {
      // 読み取り: 公開済み記事は誰でも(auth == null含む)、それ以外は権限者のみ
      // getとlistを包括的に許可
      allow read: if (resource != null && resource.data.isPublished == true) || isAuthorizedUser();
      
      // 書き込み: 学内ユーザーのみ
      allow write: if isAuthorizedUser();
    }

    // カテゴリー（categories）
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAuthorizedUser();
    }

    // ヒーロー画像（hero-images）
    match /hero-images/{imageId} {
      allow read: if true;
      allow write: if isAuthorizedUser();
    }

    // デフォルト拒否
    match /{path=**} {
      allow read, write: if false;
    }
    
    // Security Rules deployment trigger: 2024-05-23T15:30:00Z (Fixed public list and auth logic)
  }
}