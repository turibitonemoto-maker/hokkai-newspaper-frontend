
{
  "entities": {
    "Article": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Article",
      "type": "object",
      "description": "Represents a news article. Supports rich HTML (content) and PDF paper viewer (pdfUrl).",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "noteUrl": { "type": "string", "format": "uri" },
        "pdfUrl": { "type": "string", "description": "Google Drive PDF embed URL for paper viewer." },
        "source": { "type": "string" },
        "publishDate": { "type": "string", "format": "date-time" },
        "lastSyncedDate": { "type": "string", "format": "date-time" },
        "content": { "type": "string", "description": "HTML content (supports Base64 images)." },
        "summary": { "type": "string" },
        "mainImageUrl": { "type": "string", "format": "uri" },
        "mainImageCaption": { "type": "string", "description": "Caption for the main article image." },
        "isPublished": { "type": "boolean" },
        "categoryId": { "type": "string" },
        "authorName": { "type": "string" }
      },
      "required": ["id", "title", "publishDate", "isPublished", "categoryId"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Advertisement": {
      "title": "Advertisement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "linkUrl": { "type": "string", "format": "uri" },
        "displayEndTime": { "type": "string" }
      },
      "required": ["id", "imageUrl"]
    },
    "Greeting": {
      "title": "Greeting",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorName": { "type": "string" },
        "authorImageUrl": { "type": "string", "format": "uri" }
      }
    },
    "AboutUs": {
      "title": "AboutUs",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "purpose": { "type": "string" },
        "activities": { "type": "string" }
      }
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "type": "object",
      "properties": {
        "isMaintenanceMode": { "type": "boolean" },
        "maintenanceMessage": { "type": "string" }
      }
    }
  },
  "auth": { "providers": ["google.com"] },
  "firestore": {
    "/articles/{articleId}": { "schema": { "$ref": "#/backend/entities/Article" }, "description": "Articles collection." },
    "/categories/{categoryId}": { "schema": { "$ref": "#/backend/entities/Category" }, "description": "Categories." },
    "/ads/{adId}": { "schema": { "$ref": "#/backend/entities/Advertisement" }, "description": "Ads." },
    "/settings/president_greeting": { "schema": { "$ref": "#/backend/entities/Greeting" }, "description": "President greeting." },
    "/settings/about_us": { "schema": { "$ref": "#/backend/entities/AboutUs" }, "description": "About Us content." },
    "/settings/maintenance": { "schema": { "$ref": "#/backend/entities/SiteSettings" }, "description": "Global settings." }
  }
}
