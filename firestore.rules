rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 全てのドキュメント（articles, categories, hero-images等）の読み取りを完全に一般公開
    // 認証(auth)の状態に関わらず、誰でも読み取り(list, get)を許可します
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // 最終更新: 2024-03-08T09:00:00Z (セキュリティルールを完全にパブリック閲覧用に固定)
  }
}