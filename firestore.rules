
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ニュース閲覧に必要なコレクションのみ読み取りを完全に許可
    match /articles/{articleId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /hero-images/{imageId} {
      allow read: if true;
      allow write: if false;
    }

    // その他のドキュメントはすべて拒否（セキュリティのため）
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Deployment Token: 2024-05-26T21:00:00Z (Read Only Mode)
  }
}
