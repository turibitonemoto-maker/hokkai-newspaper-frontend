
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 全てのドキュメントに対して、認証の有無を問わず読み書きを完全に許可します。
    // これにより Insufficient permissions エラーを物理的に停止させます。
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Deployment trigger: 2024-05-26T00:00:00Z (Emergency Overhaul: Fully Open & Public Access)
  }
}
