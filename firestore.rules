rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 大学メール（@hgu.jp）または管理者メールの判定
    function isAuthorizedUser() {
      return request.auth != null && 
             request.auth.token.email != null && 
             (request.auth.token.email.lower().endsWith('@hgu.jp') || request.auth.token.email == 'admin@example.com');
    }

    // 記事（articles）
    match /articles/{articleId} {
      // 読み取り: 公開記事は誰でも、未公開（下書き）は権限者のみ
      // listはクエリがisPublished == trueでフィルタされている必要がある
      allow get: if isAuthorizedUser() || (resource != null && resource.data.isPublished == true);
      allow list: if isAuthorizedUser() || (resource != null && resource.data.isPublished == true);
      
      // 書き込み: 学内ユーザーのみ
      allow write: if isAuthorizedUser();
    }

    // カテゴリー（categories）
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAuthorizedUser();
    }

    // ヒーロー画像（hero-images）
    match /hero-images/{imageId} {
      allow read: if true;
      allow write: if isAuthorizedUser();
    }

    // デフォルト拒否
    match /{path=**} {
      allow read, write: if false;
    }
    
    // Security Rules deployment trigger: 2024-05-23T00:00:00Z (Optimized for list/get and auth check)
  }
}