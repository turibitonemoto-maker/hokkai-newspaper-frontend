
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ニュースサイトとして、全ての閲覧用データを完全に公開
    // auth: null の状態でも読み取り (list, get) を許可します
    match /articles/{articleId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /hero-images/{imageId} {
      allow read: if true;
      allow write: if false;
    }

    // デフォルトですべての読み取りを許可し、書き込みのみ制限
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // Deployment Token: 2024-03-08T08:00:00Z (Emergency Fix for Permissions)
  }
}
