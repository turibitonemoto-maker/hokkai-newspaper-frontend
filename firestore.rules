rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 記事 (articles): 表示側のエラー（Insufficient permissions）を完全に防ぐため、読み取りを誰でも許可
    match /articles/{articleId} {
      allow read: if true;
      // 書き込みは管理権限（@hgu.jp）を持つユーザーのみ
      // .lower() を使用して正確に比較
      allow write: if request.auth != null && 
                   (request.auth.token.email.lower().endsWith('@hgu.jp') || 
                    request.auth.token.email == 'admin@example.com');
    }

    // カテゴリー (categories): 読み取りを誰でも許可
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ヒーロー画像 (hero-images): 読み取りを誰でも許可
    match /hero-images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // デフォルト拒否
    match /{path=**} {
      allow read, write: if false;
    }
    
    // Security Rules deployment trigger: 2024-05-24T20:45:00Z (Fixed toLower() to lower() and ensured global read)
  }
}