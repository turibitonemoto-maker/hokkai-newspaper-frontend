
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 管理者権限の判定ロジック
    function isAuthorizedEditor() {
      return request.auth != null && 
             request.auth.token.email != null && (
               request.auth.token.email.lower().endsWith('@hgu.jp') || 
               request.auth.token.email.lower() == "turibitonemoto@gmail.com" ||
               request.auth.token.email.lower() == "admin@example.com"
             );
    }

    // 記事：読み取りは全員（一覧取得 list も明示的に許可）
    match /articles/{articleId} {
      allow get, list: if true;
      allow create, update, delete: if isAuthorizedEditor();
    }

    // カテゴリー：読み取りは全員
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAuthorizedEditor();
    }

    // ヒーロー画像：読み取りは全員
    match /hero-images/{imageId} {
      allow get, list: if true;
      allow create, update, delete: if isAuthorizedEditor();
    }

    // デフォルトはすべて拒否
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
