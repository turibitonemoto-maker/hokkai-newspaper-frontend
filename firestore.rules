
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 編集者権限の判定関数
    // 学内ドメイン（@hgu.jp）または指定の管理者メールアドレスを許可
    function isEditor() {
      return request.auth != null && 
             request.auth.token.email != null && (
               request.auth.token.email.lower().endsWith('@hgu.jp') || 
               request.auth.token.email.lower() == "turibitonemoto@gmail.com" ||
               request.auth.token.email.lower() == "admin@example.com"
             );
    }

    // 記事（articles）：読み取りは全員（list/get含む）、書き込みは編集者のみ
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isEditor();
    }

    // カテゴリー（categories）：読み取りは全員、書き込みは編集者のみ
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isEditor();
    }

    // ヒーロー画像（hero-images）：読み取りは全員、書き込みは編集者のみ
    match /hero-images/{imageId} {
      allow read: if true;
      allow write: if isEditor();
    }

    // デフォルトはすべて拒否
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
