rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 記事 (articles): 公開サイトでのエラーを確実に防ぐため、読み取りを完全に開放
    match /articles/{articleId} {
      allow get, list: if true;
      // 書き込みは管理権限（@hgu.jp）を持つユーザーのみ
      allow write: if request.auth != null && 
                   (request.auth.token.email.lower().endsWith('@hgu.jp') || 
                    request.auth.token.email == 'admin@example.com');
    }

    // カテゴリー (categories): 読み取りを完全に開放
    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if request.auth != null;
    }

    // ヒーロー画像 (hero-images): 読み取りを完全に開放
    match /hero-images/{imageId} {
      allow get, list: if true;
      allow write: if request.auth != null;
    }

    // デフォルト拒否
    match /{path=**} {
      allow read, write: if false;
    }
    
    // Security Rules deployment trigger: 2024-05-24T21:00:00Z (Ensured .lower() and full read access)
  }
}