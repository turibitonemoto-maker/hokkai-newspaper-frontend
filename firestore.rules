rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 大学関係者（@hgu.jp）または指定の管理者の判定
    function isAuthorized() {
      return request.auth != null && 
             request.auth.token.email != null && (
               request.auth.token.email.lower().endsWith('@hgu.jp') || 
               request.auth.token.email.lower() == "admin@example.com"
             );
    }

    // 記事（articles）
    match /articles/{articleId} {
      // 閲覧（get, list）は一般公開（誰でも読めるように設定）
      allow read: if true;
      // 書き込み（作成・更新・削除）は許可されたアカウントのみ
      allow write: if isAuthorized();
    }

    // カテゴリー（categories）
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    // ヒーロー画像（hero-images）
    match /hero-images/{imageId} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    // デフォルトはすべて拒否
    match /{path=**} {
      allow read, write: if false;
    }
    
    // Security Rules deployment trigger: 2024-05-20T12:00:00Z (Cleaned authorization)
  }
}