rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 記事 (articles): 公開記事の一覧取得エラーを確実に防ぐため、読み取りを完全開放
    match /articles/{articleId} {
      allow read: if true;
      // 書き込みは学内アカウント（@hgu.jp）または指定の管理者に限定
      allow write: if request.auth != null && 
                   (request.auth.token.email.lower().endsWith('@hgu.jp') || 
                    request.auth.token.email == 'admin@example.com');
    }

    // カテゴリー (categories)
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null && 
                   (request.auth.token.email.lower().endsWith('@hgu.jp') || 
                    request.auth.token.email == 'admin@example.com');
    }

    // ヒーロー画像 (hero-images)
    match /hero-images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null && 
                   (request.auth.token.email.lower().endsWith('@hgu.jp') || 
                    request.auth.token.email == 'admin@example.com');
    }

    // デフォルト拒否
    match /{path=**} {
      allow read, write: if false;
    }
    
    // Security Rules deployment trigger: 2024-05-24T16:25:00Z (Force global read for all articles)
  }
}