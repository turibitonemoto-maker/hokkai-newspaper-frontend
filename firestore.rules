rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 【表示用サイトの権限設定：物理正常化】
    
    // 1. 公開データの読み取り許可 (ログイン不要)
    // 記事、カテゴリー、広告、設定の各コレクションを明示的に許可します。
    match /articles/{docId} { allow read: if true; }
    match /categories/{docId} { allow read: if true; }
    match /ads/{docId} { allow read: if true; }
    match /settings/{docId} { allow read: if true; }
    
    // 再帰的な読み取り許可 (不測の403エラーを物理的に遮断)
    match /{document=**} {
      allow read: if true;
    }

    // 2. 書き込み権限 (指定された管理者のみ)
    match /{document=**} {
      allow write: if request.auth != null && (
        request.auth.token.email == "r06hgunews@gmail.com" || 
        request.auth.token.email == "turibitonemoto@gmail.com"
      );
    }
  }
}