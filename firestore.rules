
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ログイン機能を完全に廃止し、誰でも読み書きを可能にします。
    // これにより auth: null のリクエストもすべて許可され、権限エラーを物理的に消滅させます。
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Deployment Token: 2024-05-26T20:00:00Z (Full Open Mode)
  }
}
