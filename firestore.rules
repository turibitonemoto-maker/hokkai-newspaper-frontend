rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 【最優先規律：全周無死角・読み取り開放】
    // 閲覧専用サイト（デネブ）の正常稼働を物理的に保証するため、全ての読み取りを最上位で無条件に許可します。
    // メンテナンス設定、広告、記事、全てのアーカイブが含まれます。
    match /{document=**} {
      allow read: if true;
    }

    // 【管理者権限：書き込み制限】
    // データの変更は、指定された管理者のみに許可されます。
    match /{document=**} {
      allow write: if request.auth != null && (
        request.auth.token.email == "r06hgunews@gmail.com" || 
        request.auth.token.email == "turibitonemoto@gmail.com"
      );
    }
    
    // 物理的デプロイメント・トリガー: 2025-02-21 最終正常化完了
  }
}
