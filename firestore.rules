
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 判定をより確実にするため、lower()を使用したCEL式での文字列マッチングを採用
    function isAuthorizedEditor() {
      return request.auth != null && (
        request.auth.token.email.lower() == "admin@example.com" || 
        request.auth.token.email.lower().endsWith('@hgu.jp')
      );
    }

    match /articles/{articleId} {
      allow read, list: if true;
      allow create, update, delete: if isAuthorizedEditor();
    }

    match /categories/{categoryId} {
      allow read, list: if true;
      allow create, update, delete: if isAuthorizedEditor();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
